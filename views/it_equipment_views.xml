<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_it_equipment_form" model="ir.ui.view">
        <field name="name">it.equipment.form</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <form string="Équipement informatique">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom de l'équipement"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="model"/>
                            <field name="serial_number"/>
                            <field name="client_id"/>
                            <field name="site_id"/>
                        </group>
                        <group>
                            <field name="purchase_date"/>
                            <field name="warranty_end_date"/>
                            <field name="purchase_value" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="current_value" widget="monetary"/>
                            <field name="amortization_years"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_it_equipment_tree" model="ir.ui.view">
        <field name="name">it.equipment.list</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="model"/>
                <field name="serial_number"/>
                <field name="client_id"/>
                <field name="status"/>
                <field name="purchase_date"/>
                <field name="current_value" widget="monetary"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_it_equipment_search" model="ir.ui.view">
        <field name="name">it.equipment.search</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <search string="Rechercher un équipement">
                <field name="name"/>
                <field name="serial_number"/>
                <field name="model"/>
                <field name="client_id"/>
                <separator/>
                <filter string="Opérationnel" name="operational" domain="[('status', '=', 'operational')]"/>
                <filter string="En maintenance" name="maintenance" domain="[('status', '=', 'maintenance')]"/>
                <filter string="Retiré" name="retired" domain="[('status', '=', 'retired')]"/>
                <group expand="0" string="Group By">
                    <filter string="Client" name="client" context="{'group_by': 'client_id'}"/>
                    <filter string="Site" name="site" context="{'group_by': 'site_id'}"/>
                    <filter string="Statut" name="status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_it_equipment" model="ir.actions.act_window">
        <field name="name">Équipements informatiques</field>
        <field name="res_model">it.equipment</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_it_equipment"
              name="Équipements informatiques"
              action="action_it_equipment"
              parent="menu_it_asset_management"
              sequence="15"/>
</odoo>